---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import perfil from "../assets/perfil01.jpg";

const posts = await getCollection("blogs");
---

<Layout>
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-12">
    <aside class="md:w-[30%] min-w-0 md:sticky md:top-8 md:self-start">
      <div class="relative border-2 border-neutral-900 overflow-hidden">
        <div class="px-6 pt-6 pb-3 border-b-2 border-neutral-900">
          <h1 class="text-2xl font-extrabold tracking-tight text-neutral-900">
            Alva Vidal
          </h1>
          <p class="text-neutral-500 text-xs mt-1 tracking-wide">
            — 思ったこと、感じたこと —
          </p>
        </div>
        <img
          src={perfil.src}
          alt="Foto de perfil"
          class="relative w-full h-auto max-h-[50vh] md:max-h-none object-contain"
        />

        <div class="flex flex-wrap gap-3 border-t-2 border-neutral-900 px-6 py-4">
          <span class="px-4 py-1.5 border-2 border-amber-600 bg-amber-200 text-amber-900 text-xs font-bold tracking-wide -rotate-1">
            Desarrollador
          </span>
          <span class="px-4 py-1.5 border-2 border-amber-600 bg-amber-200 text-amber-900 text-xs font-bold tracking-wide rotate-1">
            Politólogo
          </span>
        </div>
        <div class="border-t-2 border-neutral-900 px-6 py-4">
          <p class="text-neutral-600 text-sm leading-relaxed">
            Interesado en datos, automatización, inteligencia artificial y sistemas de apoyo a decisiones.
          </p>
        </div>
      </div>
    </aside>

    <main class="md:w-[70%] min-w-0 space-y-10">
      

      {
        posts.map((post) => {
          const { id, data } = post;
          const { title, author, description } = data;

          return (
            <article class="border-2 border-neutral-900 p-6 relative">
              <div class="absolute -top-2.5 -left-2.5 w-5 h-5 bg-neutral-900" />
              <div class="absolute -top-2.5 -right-2.5 w-5 h-5 bg-neutral-900" />
              <div class="absolute -bottom-2.5 -left-2.5 w-5 h-5 bg-neutral-900" />
              <div class="absolute -bottom-2.5 -right-2.5 w-5 h-5 bg-neutral-900" />
              <h2 class="text-2xl font-bold tracking-tight mb-1" transition:name={`post-title-${id}`}>{title}</h2>
              <p class="text-neutral-500 text-xs mb-3">
                <em class="text-blue-900">Por {author}</em>
              </p>
              <p class="text-neutral-700 text-sm leading-relaxed">
                {description}
              </p>
              <div class="mt-4">
                <a
                  href={`/blog/${id}`}
                  class="inline-block px-5 py-2 border-2 border-neutral-900 text-sm font-bold tracking-wide text-neutral-900 hover:bg-neutral-900 hover:text-neutral-50 transition-colors duration-200"
                >
                  Ver mas...
                </a>
              </div>
            </article>
          );
        })
      }
    </main>
  </div>
</Layout>
