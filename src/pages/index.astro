---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import perfil from "../assets/perfil01.jpg";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";

const posts = await getCollection("blogs");
const proyectos = await getCollection("proyectos");
const recentPosts = posts.slice(0, 3);
const featuredProjects = proyectos.slice(0, 3);
---

<!-- ╔══════════════════════════════════════════════════╗
     ║   L A Y O U T   P R I N C I P A L             ║
     ╚══════════════════════════════════════════════════╝ -->
<Layout lockViewport
  seoTitle="Alvaro Vidal | Politólogo, Analista de Datos & Est. Desarrollo de Sistemas"
  seoDescription="Portafolio de Alvaro Vidal Velasque, estudiante de Desarrollo de Sistemas en IDAT, politólogo y analista de datos en Lima, Perú. Especialista en presupuesto público, logística pública, ciencia política y derecho internacional.">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-4 md:gap-3 lg:h-full lg:min-h-0 lg:overflow-hidden">

    <!-- ╔══════════════════════════════════════════════╗
         ║   F I L A   S U P E R I O R               ║
         ║   aside (30%)  +  main (70%)              ║
         ╚══════════════════════════════════════════════╝ -->
    <div class="flex flex-col gap-4 md:min-h-0 md:flex-row md:gap-5 lg:flex-[3] lg:overflow-hidden">

      <!-- ───[ A S I D E   —   P E R F I L ]────────── -->
      <aside class="min-w-0 md:min-h-0 md:w-[30%]">
        <div class="relative flex flex-col overflow-hidden border border-neutral-800 dark:border-neutral-600 bg-white dark:bg-neutral-900 lg:h-full md:min-h-0">
          <!-- ── header ── -->
          <div class="shrink-0 border-b-2 border-neutral-900 dark:border-neutral-700 px-4 pb-2 pt-3 text-center">
            <h1 class="text-lg font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-xl">
              Alva Vidal
            </h1>
            <p class="mt-0.5 text-xs tracking-wide text-neutral-500 dark:text-neutral-400">
              — 思ったこと、感じたこと —
            </p>
          </div>
          <!-- ── foto ── -->
          <img
            src={perfil.src}
            alt="Foto de perfil"
            class="relative min-h-0 w-full flex-1 object-contain"
          />
          <!-- ── tags (sticker) ── -->
          <div class="flex shrink-0 flex-wrap justify-center gap-1.5 border-t-2 border-neutral-900 dark:border-neutral-700 px-3 py-1.5">
            <span class="inline-block -rotate-2 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-2.5 py-0.5 text-[10px] font-extrabold tracking-wide text-amber-950 dark:text-amber-950 shadow-[3px_3px_0_#111827] dark:shadow-none md:px-3 md:py-1 md:text-xs">
              Desarrollador
            </span>
            <span class="inline-block rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-2.5 py-0.5 text-[10px] font-extrabold tracking-wide text-amber-950 dark:text-amber-950 shadow-[3px_3px_0_#111827] dark:shadow-none md:px-3 md:py-1 md:text-xs">
              Politólogo
            </span>
          </div>
          <!-- ── descripción ── -->
          <div class="shrink-0 border-t-2 border-neutral-900 dark:border-neutral-700 px-3 py-2">
            <p class="leading-relaxed text-neutral-600 dark:text-neutral-400 text-xs md:text-sm">
              4to Ciclo de la carrera de Desarrollo de Sistemas en Idat. Bachiller en Ciencia Política (UNMSM). Especializado en Derecho Internacional (Unisimón - Colombia).
            </p>
          </div>
          <!-- ── sobre mí ── -->
          <div class="shrink-0 border-t-2 border-neutral-900 dark:border-neutral-700 px-3 py-2.5">
            <a
              href="/about"
              class="block w-full text-center -rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-3 py-1.5 text-xs font-extrabold tracking-wide text-amber-950 dark:text-amber-950 shadow-[3px_3px_0_#111827] dark:shadow-none transition-transform hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none"
            >
              Sobre mí
            </a>
          </div>
        </div>
      </aside>

      <!-- ───[ M A I N   —   B L O G S   R E C I E N T E S ]── -->
      <main class="flex min-w-0 flex-col gap-1.5 md:min-h-0 md:w-[70%] md:gap-2 lg:overflow-hidden">
        <!-- ── header de sección ── -->
        <div class="flex shrink-0 items-center justify-between gap-4 border-b-2 border-neutral-900 dark:border-neutral-700 pb-1">
          <h2 class="text-base font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-lg">
            Blogs recientes
          </h2>
          <a
            href="/blog"
            class="inline-block -rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-2.5 py-0.5 text-xs font-extrabold tracking-wide text-amber-950 dark:text-amber-950 shadow-[3px_3px_0_#111827] dark:shadow-none transition-transform hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none"
          >
            Ver todos
          </a>
        </div>

        <!-- ── tarjetas de posts ── -->
        <div class="flex flex-col gap-1.5 md:min-h-0 md:flex-1 lg:overflow-hidden">
          {
            recentPosts.map((post) => {
              const { id, data } = post;
              const { title, author, description } = data;

              return (
                <BlogCard
                  compact
                  id={id}
                  title={title}
                  author={author}
                  description={description}
                />
              );
            })
          }
        </div>
      </main>
    </div>

    <!-- ╔══════════════════════════════════════════════╗
         ║   S E C C I Ó N   I N F E R I O R          ║
         ║   Proyectos destacados (grid 3 col)        ║
         ╚══════════════════════════════════════════════╝ -->
    <section class="flex flex-col gap-1.5 md:min-h-0 md:gap-2 md:pb-2 lg:flex-[1.4] lg:overflow-hidden">
      <!-- ── header de sección ── -->
      <div class="flex shrink-0 items-center justify-between gap-4 border-b-2 border-neutral-900 dark:border-neutral-700 pb-1">
        <h2 class="text-base font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-lg">
          Proyectos destacados
        </h2>
        <a
          href="/proyecto"
          class="inline-block rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-2.5 py-0.5 text-xs font-extrabold tracking-wide text-amber-950 dark:text-amber-950 shadow-[3px_3px_0_#111827] dark:shadow-none transition-transform hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none"
        >
          Ver todos
        </a>
      </div>

      <!-- ── grid de tarjetas ── -->
<div class="grid grid-cols-1 gap-3 md:min-h-0 md:grid-cols-2 md:items-stretch lg:flex-1 lg:grid-cols-3 lg:overflow-hidden lg:max-h-60">
        {
          featuredProjects.map((project) => {
            const { id, data } = project;
            const { title, author, description, technologies, status, github } = data;

            return (
              <ProjectCard
                compact
                id={id}
                title={title}
                author={author}
                description={description}
                technologies={technologies}
                status={status}
                github={github}
              />
            );
          })
        }
      </div>
    </section>

  </div>
</Layout>
