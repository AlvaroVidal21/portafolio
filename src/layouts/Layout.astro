---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  lockViewport?: boolean;
  seoTitle?: string;
  seoDescription?: string;
}

const DEFAULT_TITLE = "Alvaro Vidal | Politólogo, Analista de Datos & Est. Desarrollo de Sistemas";
const DEFAULT_DESC = "Portafolio de Alvaro Vidal Velasque, estudiante de Desarrollo de Sistemas en IDAT, politólogo y analista de datos en Lima, Perú. Especialista en presupuesto público, logística pública, ciencia política y derecho internacional.";

const { lockViewport = false, seoTitle = DEFAULT_TITLE, seoDescription = DEFAULT_DESC } = Astro.props;

const pathname = Astro.url.pathname;
const siteUrl = "https://alvavidal.dev";
const canonicalUrl = `${siteUrl}${pathname}`;

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/proyecto", label: "Proyectos" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "Sobre mí" },
];

const currentPage =
  navItems.find((item) =>
    item.href === "/" ? pathname === "/" : pathname.startsWith(item.href),
  ) || navItems[0];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/vendetta.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta name="keywords" content="alvaro vidal velasque, alvaro daniel vidal velasque, politólogo, analista de datos, idat, desarrollo de sistemas, presupuesto público, logística pública, lima, perú, siaf, ciencia política" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />

    <!-- JSON-LD Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alvaro Daniel Vidal Velasque",
      "alternateName": "Alvaro Vidal",
      "jobTitle": ["Politólogo", "Analista de Datos", "Desarrollador de Sistemas"],
      "address": { "@type": "PostalAddress", "addressLocality": "Lima, Perú" },
      "url": siteUrl,
      "knowsAbout": ["Presupuesto Público", "Logística Pública", "Ciencia Política", "Derecho Internacional", "Desarrollo de Sistemas", "Análisis de Datos", "SIAF"],
      "alumniOf": { "@type": "CollegeOrUniversity", "name": "IDAT" }
    })} />

    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Noto+Sans+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
    <body
    class:list={[
      "bg-neutral-50 dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 font-['Inter','Noto_Sans_JP',sans-serif] antialiased leading-relaxed flex flex-col",
      lockViewport ? "min-h-screen lg:h-dvh lg:max-h-dvh lg:overflow-hidden" : "min-h-screen",
    ]}
  >
    <header class="relative border-b-2 border-neutral-900 dark:border-neutral-700">
      <div class="mx-auto flex max-w-4xl items-center justify-between px-5 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-lg font-extrabold tracking-tight dark:text-neutral-50">
          <span class="flex items-center justify-center size-10 border-2 border-neutral-900 dark:border-neutral-700 bg-white dark:bg-neutral-900 -rotate-2 shadow-[2px_2px_0_#111827] dark:shadow-none">
            <img src="/vendetta.png" alt="" class="w-7 h-7" />
          </span>
          Alva
        </a>

        <!-- Desktop nav -->
        <div class="flex items-center gap-3 md:gap-4">
          <nav class="hidden items-center gap-3 pl-3 text-[13px] font-extrabold uppercase tracking-[0.18em] md:ml-5 md:flex">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
                return (
                  <a
                    href={item.href}
                    class:list={[
                      "group relative inline-flex -skew-x-6 items-center overflow-hidden border-2 border-neutral-900 px-3 py-1 shadow-[2px_2px_0_#111827] transition-all hover:-translate-y-0.5 dark:border-neutral-700 dark:shadow-none",
                      isActive
                        ? "-rotate-1 bg-amber-300 text-neutral-950 dark:bg-[#D6A21E] dark:text-neutral-950"
                        : "bg-white text-neutral-900 dark:bg-neutral-900 dark:text-neutral-100",
                    ]}
                  >
                    <span aria-hidden="true" class:list={[
                      "pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.18)_1px,transparent_0)] bg-[size:5px_5px]",
                      isActive ? "opacity-35 dark:opacity-18" : "opacity-22 dark:opacity-12",
                    ]}></span>
                    <span class="relative skew-x-6">{item.label}</span>
                  </a>
                );
              })
            }
          </nav>

          <button id="theme-toggle" class="group relative hidden h-9 shrink-0 -skew-x-6 items-stretch overflow-hidden border-2 border-neutral-900 bg-white shadow-[2px_2px_0_#111827] transition-all hover:-translate-y-0.5 dark:border-neutral-700 dark:bg-neutral-950 dark:shadow-none md:inline-flex" aria-label="Cambiar tema" title="Cambiar tema">
            <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.12)_1px,transparent_0)] bg-[size:6px_6px] opacity-25 dark:opacity-15"></span>
            <span class="relative flex size-9 items-center justify-center border-r-2 border-neutral-900 bg-amber-200 text-neutral-950 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
              <svg class="h-3.5 w-3.5 skew-x-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                <circle cx="12" cy="12" r="5"/>
              </svg>
            </span>
            <span class="relative flex size-9 items-center justify-center bg-neutral-100 text-neutral-700 dark:bg-[#D6A21E] dark:text-neutral-950">
              <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.12)_1px,transparent_0)] bg-[size:5px_5px] opacity-14 dark:bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.12)_1px,transparent_0)] dark:opacity-24"></span>
              <svg class="h-3.5 w-3.5 skew-x-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
        </div>

        <!-- Mobile: current page sticker + hamburger -->
        <div class="flex items-center gap-3 md:hidden">
          <button id="theme-toggle-mobile" class="group relative inline-flex h-9 shrink-0 -skew-x-6 items-stretch overflow-hidden border-2 border-neutral-900 bg-white shadow-[1px_1px_0_#111827] transition-all hover:-translate-y-0.5 dark:border-neutral-700 dark:bg-neutral-950 dark:shadow-none" aria-label="Cambiar tema" title="Cambiar tema">
            <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.12)_1px,transparent_0)] bg-[size:6px_6px] opacity-22 dark:opacity-12"></span>
            <span aria-hidden="true" class="pointer-events-none absolute left-0 top-0 h-full w-[48%] bg-[linear-gradient(135deg,rgba(251,191,36,0.1)_0%,rgba(251,191,36,0.1)_48%,transparent_48%,transparent_100%)] opacity-55 dark:opacity-30"></span>
            <span class="relative flex size-9 items-center justify-center border-r-2 border-neutral-900 bg-amber-200 text-neutral-950 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
              <svg class="h-3.5 w-3.5 skew-x-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                <circle cx="12" cy="12" r="5"/>
              </svg>
            </span>
            <span class="relative flex size-9 items-center justify-center bg-neutral-100 text-neutral-700 dark:bg-[#D6A21E] dark:text-neutral-950">
              <span aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(17,24,39,0.12)_1px,transparent_0)] bg-[size:4px_4px] opacity-15 dark:opacity-24"></span>
              <svg class="h-3.5 w-3.5 skew-x-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
          <span
            class="-rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-3 py-1 text-[11px] font-extrabold uppercase tracking-[0.18em] shadow-[2px_2px_0_#111827] dark:shadow-none"
          >
            {currentPage.label}
          </span>
          <button
            id="menu-toggle"
            class="flex size-9 items-center justify-center border-2 border-neutral-900 bg-white shadow-[2px_2px_0_#111827] dark:border-neutral-700 dark:bg-neutral-900 dark:shadow-none"
            aria-label="Abrir menú"
          >
            <span id="menu-icon" class="text-[1.15rem] font-black leading-none">☰</span>
          </button>
        </div>
      </div>

      <!-- Mobile dropdown menu -->
      <div
        id="mobile-menu"
        class="hidden border-t-2 border-neutral-900 dark:border-neutral-700 bg-white dark:bg-neutral-900 md:hidden"
      >
        <nav class="flex flex-col px-5 py-3 text-sm font-semibold uppercase tracking-widest">
          {
            navItems.map((item) => {
              const isActive =
                item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class:list={[
                    "border-b border-neutral-200 dark:border-neutral-700 py-3 last:border-none transition-all",
                    isActive
                      ? "-rotate-1 border-2 border-neutral-900 dark:border-neutral-700 bg-amber-300 dark:bg-[#D6A21E] px-3 shadow-[2px_2px_0_#111827] dark:shadow-none"
                      : "hover:text-neutral-500 dark:hover:text-neutral-300",
                  ]}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <main
      class:list={[
        "flex-1 px-5 pt-8",
        lockViewport && "lg:flex lg:min-h-0 lg:flex-col lg:overflow-hidden",
      ]}
    >
      <slot />
    </main>

    <footer class="border-t-2 border-neutral-900 dark:border-neutral-700">
      <div class="mx-auto max-w-4xl px-5 py-4 text-center text-xs tracking-wider text-neutral-500 dark:text-neutral-500">
        &copy; 2026 Alva Vidal
      </div>
    </footer>

    <script>
      function setupTheme() {
        const stored = localStorage.getItem("theme");
        const prefers = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = stored === "dark" || (!stored && prefers);

        document.documentElement.classList.toggle("dark", isDark);

        const toggle = document.getElementById("theme-toggle");
        const toggleMobile = document.getElementById("theme-toggle-mobile");

        function handleClick() {
          const html = document.documentElement;
          html.classList.add("transitioning");
          const isDark = !html.classList.contains("dark");
          html.classList.toggle("dark", isDark);
          localStorage.setItem("theme", isDark ? "dark" : "light");
          setTimeout(() => html.classList.remove("transitioning"), 400);
        }

        [toggle, toggleMobile].filter(Boolean).forEach((btn) => {
          const newBtn = btn.cloneNode(true);
          btn.replaceWith(newBtn);
          newBtn.addEventListener("click", handleClick);
        });
      }

      function setupMobileMenu() {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const icon = document.getElementById("menu-icon");
        if (!toggle || !menu || !icon) return;

        menu.classList.add("hidden");
        menu.classList.remove("flex");
        icon.textContent = "☰";

        const newToggle = toggle.cloneNode(true);
        toggle.replaceWith(newToggle);

        newToggle.addEventListener("click", () => {
          const isHidden = menu.classList.contains("hidden");
          menu.classList.toggle("hidden");
          menu.classList.toggle("flex");
          icon.textContent = isHidden ? "✕" : "☰";
        });

        menu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            menu.classList.add("hidden");
            menu.classList.remove("flex");
            icon.textContent = "☰";
          });
        });
      }

      setupTheme();
      setupMobileMenu();
      document.addEventListener("astro:page-load", () => {
        setupTheme();
        setupMobileMenu();
      });
    </script>
  </body>
</html>
